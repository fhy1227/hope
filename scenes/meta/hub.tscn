[gd_scene format=3 uid="uid://chubscene01"]

[ext_resource type="Script" path="res://scripts/meta/ui/HubUI.cs" id="1_hub"]
[ext_resource type="Theme" path="res://assets/ui/theme/hope_unified_theme.tres" id="2_theme"]

[node name="Hub" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
